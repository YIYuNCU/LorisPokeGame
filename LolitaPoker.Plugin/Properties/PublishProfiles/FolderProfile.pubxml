<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>9000_LolitaPoker\plugin</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>

    <!-- 框架依赖，仅 win-x64（VPet 已提供 .NET 运行时） -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
  </PropertyGroup>

  <!-- 发布后清理无用文件 -->
  <Target Name="CleanupAfterPublish" AfterTargets="Publish">
    <Message Text="清理发布输出..." Importance="high" />

    <!-- 计算绝对路径 -->
    <PropertyGroup>
      <_AbsPublishDir>$([System.IO.Path]::GetFullPath('$(PublishDir)'))</_AbsPublishDir>
    </PropertyGroup>

    <!-- 清理非 Windows 运行时 -->
    <ItemGroup>
      <UnwantedRuntimes Include="
          $(_AbsPublishDir)\runtimes\linux-**;
          $(_AbsPublishDir)\runtimes\osx-**;
          $(_AbsPublishDir)\runtimes\freebsd-**;
          $(_AbsPublishDir)\runtimes\alpine-**;
          $(_AbsPublishDir)\runtimes\browser-**;
          $(_AbsPublishDir)\runtimes\ios-**;
          $(_AbsPublishDir)\runtimes\android-**;
          $(_AbsPublishDir)\runtimes\tvos-**" />
    </ItemGroup>

    <RemoveDir Directories="@(UnwantedRuntimes)" />

    <!-- 清理开发文件 -->
    <ItemGroup>
      <_DevFilesToDelete Include="$(_AbsPublishDir)\**\*.pdb" />
      <_DevFilesToDelete Include="$(_AbsPublishDir)\**\*.deps.json" />
      <_DevFilesToDelete Include="$(_AbsPublishDir)\**\*.xml" />
      <_DevFilesToDelete Include="$(_AbsPublishDir)\**\*.dev.json" />
    </ItemGroup>

    <Delete Files="@(_DevFilesToDelete)" />

    <!-- 清理空 runtimes 目录 -->
    <RemoveDir Directories="$(_AbsPublishDir)\runtimes"
                Condition="!Exists('$(_AbsPublishDir)\runtimes\win-*')" />

    <!-- 清理冗余的 pics（Content item 带入的，实际应放在分发目录根级 pics/） -->
    <RemoveDir Directories="$(_AbsPublishDir)\pics" />

    <Message Text="清理完成" Importance="high" />
  </Target>

  <!-- 发布后复制卡牌图片到分发目录 -->
  <Target Name="CopyPicsToPublish" AfterTargets="Publish">
    <ItemGroup>
      <PicsToCopy Include="..\pics\**\*.png" />
    </ItemGroup>
    <Copy SourceFiles="@(PicsToCopy)"
          DestinationFolder="9000_LolitaPoker\pics\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
    <Message Text="已复制卡牌图片到 9000_LolitaPoker\pics\" Importance="high" />
  </Target>
</Project>
