<Window x:Class="LolitaPoker.Plugin.GameHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LolitaPoker.Core.Views;assembly=LolitaPoker.Core"
        xmlns:vms="clr-namespace:LolitaPoker.Core.ViewModels;assembly=LolitaPoker.Core"
        Title="萝莉丝扑克 - VPet 联机"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- 隐式 DataTemplate：GameViewModel → GameTableControl -->
        <DataTemplate DataType="{x:Type vms:GameViewModel}">
            <views:GameTableControl/>
        </DataTemplate>
    </Window.Resources>

    <!-- 直接展示 GameTableControl -->
    <ContentControl Content="{Binding}"/>
</Window>
