<UserControl x:Class="LolitaPoker.Core.Views.NetworkSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LolitaPoker.Core.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SettingButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4a6fa5"/>
            <Setter Property="BorderBrush" Value="#2c3e50"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a8fc5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a5f95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SettingButton}">
            <Setter Property="Background" Value="#27ae60"/>
        </Style>

        <Style x:Key="SettingTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3a5f95"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>

        <!-- 暗色主题 CheckBox -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBorder" Width="18" Height="18"
                                    Background="#1a1a2e" BorderBrush="#3a5f95" BorderThickness="1.5"
                                    CornerRadius="3" VerticalAlignment="Center">
                                <TextBlock x:Name="checkMark" Text="✓" Foreground="#27ae60"
                                           FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#27ae60"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#5a8fc5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>    <!-- 菜单栏 -->
            <RowDefinition Height="*"/>     <!-- 内容 -->
        </Grid.RowDefinitions>

        <!-- ==================== 菜单栏 ==================== -->
        <Border Grid.Row="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：返回 -->
                <Button Grid.Column="0" Content="{Binding BackButtonText}"
                        Command="{Binding BackCommand}"
                        Margin="8,0,0,0" VerticalAlignment="Center"
                        Foreground="#aaa" FontSize="12" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="6,2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                       Foreground="#aaa" FontSize="12" Padding="6,2"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="tb" Property="Foreground" Value="#fff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="tb" Property="Foreground" Value="#FFD700"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 右侧：页面标题 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="{Binding TitleEmoji}" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding Title}" Foreground="#aaa" FontSize="13"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 内容区 ==================== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Stretch">
            <StackPanel Width="780" HorizontalAlignment="Center" Margin="40,25">

                <!-- ========== 主页面（IsShowingLobby=false） ========== -->
                <StackPanel Visibility="{Binding IsShowingLobby, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">

                    <!-- 标题 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                        <TextBlock Text="{Binding TitleEmoji}" FontSize="30" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold"
                                   Foreground="#FFD700" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Subtitle}" FontSize="14"
                               Foreground="#777" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- 设置卡片 -->
                    <Border Background="#16213e" CornerRadius="12" Padding="24,16" Margin="0,0,0,14"
                            BorderBrush="#2c3e50" BorderThickness="1">
                        <StackPanel>
                            <!-- P2P 专属设置 -->
                            <StackPanel Visibility="{Binding IsP2PMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="IP 地址" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingTextBox}"/>

                                <TextBlock Text="端口" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingTextBox}" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- 服务器专属设置 -->
                            <StackPanel Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="服务器地址" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SettingTextBox}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 连接方式卡片（P2P模式） -->
                    <Border Background="#16213e" CornerRadius="12" Padding="20,16" Margin="0,0,0,14"
                            BorderBrush="#2c3e50" BorderThickness="1"
                            Visibility="{Binding IsP2PMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="选择连接方式" Foreground="#aaa" FontSize="14" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="创建房间"
                                        Command="{Binding CreateRoomCommand}"
                                        Style="{StaticResource PrimaryButton}"/>
                                <Button Content="加入房间"
                                        Command="{Binding JoinRoomCommand}"
                                        Style="{StaticResource SettingButton}" Background="#e67e22"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 连接方式卡片（服务器模式） -->
                    <Border Background="#16213e" CornerRadius="12" Padding="24,16" Margin="0,0,0,14"
                            BorderBrush="#2c3e50" BorderThickness="1"
                            Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="选择连接方式" Foreground="#aaa" FontSize="14"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- 创建房间（左） + 加入房间（右） 横向并排 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 创建房间 -->
                                <Border Grid.Column="0" Background="#1a1a2e" CornerRadius="8" Padding="16,12"
                                        BorderBrush="#2c3e50" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="🏠 创建房间" Foreground="#FFD700" FontSize="15"
                                                   FontWeight="Bold" Margin="0,0,0,10"/>
                                        <CheckBox IsChecked="{Binding IsPublicRoom}"
                                                  Style="{StaticResource DarkCheckBox}"
                                                  Margin="0,0,0,12">
                                            <StackPanel Margin="0,-2,0,0">
                                                <TextBlock Text="公开房间" Foreground="#aaa" FontSize="14"/>
                                                <TextBlock Text="（在大厅中显示）" Foreground="#888" FontSize="12"/>
                                            </StackPanel>
                                        </CheckBox>
                                        <Button Content="创建"
                                                Command="{Binding CreateRoomCommand}"
                                                Style="{StaticResource PrimaryButton}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 加入房间 -->
                                <Border Grid.Column="2" Background="#1a1a2e" CornerRadius="8" Padding="16,12"
                                        BorderBrush="#2c3e50" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="🔗 加入房间" Foreground="#e67e22" FontSize="15"
                                                   FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TextBlock Text="房间号" Style="{StaticResource FieldLabel}" Margin="0,0,0,0"/>
                                        <TextBox Text="{Binding RoomCode, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SettingTextBox}"
                                                 Margin="0,3,0,12"/>
                                        <Button Content="加入"
                                                Command="{Binding JoinRoomCommand}"
                                                Style="{StaticResource SettingButton}" Background="#e67e22"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- 查找公开房间 -->
                            <Border Background="#1a1a2e" CornerRadius="8" Padding="16,12"
                                    BorderBrush="#2c3e50" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonDown="OnLobbyCardClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔍 查找公开房间" Foreground="#4a9eff" FontSize="15"
                                                   FontWeight="Bold" Margin="0,0,0,3"/>
                                        <TextBlock Text="浏览服务器上的公开房间并加入" Foreground="#777" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="→" Foreground="#4a9eff" FontSize="20"
                                               VerticalAlignment="Center" Margin="10,0,4,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 连接状态 -->
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{Binding ConnectionStatusColor}"
                               FontSize="15" HorizontalAlignment="Center"
                               Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ========== 大厅二级页面（IsShowingLobby=true） ========== -->
                <StackPanel Visibility="{Binding IsShowingLobby, Converter={StaticResource BoolToVis}}">

                    <!-- 标题 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                        <TextBlock Text="🏠" FontSize="30" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="公开房间" FontSize="28" FontWeight="Bold"
                                   Foreground="#FFD700" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="选择一个房间加入" FontSize="14"
                               Foreground="#777" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- 房间列表卡片 -->
                    <Border Background="#16213e" CornerRadius="12" Padding="20,16" Margin="0,0,0,14"
                            BorderBrush="#2c3e50" BorderThickness="1">
                        <StackPanel>
                            <!-- 标题栏 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="在线房间" Foreground="#aaa" FontSize="15"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="🔄 刷新"
                                        Command="{Binding RefreshRoomListCommand}"
                                        Style="{StaticResource SettingButton}" Margin="12,0,0,0"
                                        MinWidth="80" Padding="14,4" FontSize="13"/>
                            </StackPanel>

                            <!-- 加载中 -->
                            <TextBlock Text="正在加载..." Foreground="#777" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,5"
                                       Visibility="{Binding IsLoadingRooms, Converter={StaticResource BoolToVis}}"/>

                            <!-- 空列表提示 -->
                            <Border Background="#1a1a2e" CornerRadius="8" Padding="20,24" Margin="0,5"
                                    Visibility="{Binding HasRooms, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="暂无公开房间" Foreground="#555" FontSize="15"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="去创建一个房间邀请朋友吧！" Foreground="#444" FontSize="12"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- 房间列表 -->
                            <ItemsControl ItemsSource="{Binding RoomList}" MaxHeight="360">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1a2e" CornerRadius="8" Padding="16,12" Margin="0,4"
                                                BorderBrush="#2c3e50" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Foreground="#FFD700" FontSize="15" FontWeight="Bold"
                                                                   FontFamily="Consolas"
                                                                   Text="{Binding RoomCode, Mode=OneWay}"/>
                                                        <TextBlock Foreground="#666" FontSize="12" Margin="10,0,0,0"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}/{1} 人">
                                                                    <Binding Path="PlayerCount" Mode="OneWay"/>
                                                                    <Binding Path="MaxPlayers" Mode="OneWay"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Foreground="#888" FontSize="12" Margin="0,3,0,0"
                                                               Text="{Binding PlayersText, Mode=OneWay}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="加入" Width="64" Height="32"
                                                        Style="{StaticResource PrimaryButton}" FontSize="13"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.JoinSelectedRoomCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding RoomCode}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 连接状态 -->
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{Binding ConnectionStatusColor}"
                               FontSize="15" HorizontalAlignment="Center"
                               Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
