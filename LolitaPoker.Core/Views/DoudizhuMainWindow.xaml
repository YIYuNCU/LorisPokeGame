<Window x:Class="LolitaPoker.Core.Views.DoudizhuMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LolitaPoker.Core.Views"
        xmlns:vm="clr-namespace:LolitaPoker.Core.ViewModels"
        Title="萝莉丝扑克 - 斗地主"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="CanResize"
        Closing="OnWindowClosing"
        Loaded="OnWindowLoaded"
        Background="#1a1a2e">

    <Window.Resources>
        <!-- 隐式 DataTemplate：根据 ViewModel 类型自动选择 View -->
        <DataTemplate DataType="{x:Type vm:ModeSelectViewModel}">
            <views:ModeSelectView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkSettingsViewModel}">
            <views:NetworkSettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameViewModel}">
            <views:GameTableControl />
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding CurrentViewModel}" />
</Window>
