<UserControl x:Class="LolitaPoker.Core.Views.GameTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LolitaPoker.Core.Converters"
             xmlns:vm="clr-namespace:LolitaPoker.Core.ViewModels"
             xmlns:views="clr-namespace:LolitaPoker.Core.Views">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis2"/>

        <Style x:Key="PlayerLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4a6fa5"/>
            <Setter Property="BorderBrush" Value="#2c3e50"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="20,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a8fc5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a5f95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#666"/>
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PassButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#c0392b"/>
        </Style>

        <Style x:Key="HintButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#27ae60"/>
        </Style>

        <Style x:Key="NewGameButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="#f39c12"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="GameGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>    <!-- 菜单栏 -->
            <RowDefinition Height="75"/>    <!-- AI信息 + 底牌 -->
            <RowDefinition Height="*"/>     <!-- 出牌区域 -->
            <RowDefinition Height="Auto"/>  <!-- 玩家出牌 -->
            <RowDefinition Height="Auto"/>  <!-- 手牌 + 操作按钮 -->
        </Grid.RowDefinitions>

        <!-- ==================== 菜单栏 ==================== -->
        <Border Grid.Row="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：返回主页按钮 -->
                <Button Grid.Column="0" Content="← 返回主页"
                        Command="{Binding BackToMenuCommand}"
                        IsEnabled="{Binding IsBackToMenuVisible}"
                        Margin="8,0,0,0" VerticalAlignment="Center"
                        Foreground="#aaa" FontSize="12" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="6,2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="tb" Text="{TemplateBinding Content}"
                                       Foreground="#aaa" FontSize="12" Padding="6,2"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="tb" Property="Foreground" Value="#fff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="tb" Property="Foreground" Value="#FFD700"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="tb" Property="Foreground" Value="#555"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 右侧：房间号（仅服务器模式，点击复制） -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,6,0"
                            Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="房间:" Foreground="#777" FontSize="12" VerticalAlignment="Center"/>
                    <Border x:Name="RoomCodeBorder" Background="#222" CornerRadius="4" Padding="8,2"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                            Margin="3,0,0,0" MouseLeftButtonDown="OnRoomCodeClick">
                        <TextBlock Text="{Binding RoomCode}" Foreground="#FFD700"
                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas"/>
                    </Border>
                    <!-- 复制反馈 -->
                    <TextBlock Text="{Binding CopyFeedback}" Foreground="#27ae60" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>

                    <!-- 房间可见性切换 -->
                    <Border x:Name="VisibilityBorder" Background="#222" CornerRadius="4" Padding="8,2"
                            BorderBrush="#555" BorderThickness="1"
                            Margin="6,0,0,0" MouseLeftButtonDown="OnVisibilityToggle"
                            Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding IsRoomVisibilityToggleEnabled}">
                        <TextBlock Text="{Binding RoomVisibilityText}" Foreground="#aaa" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== AI信息 + 底牌 ==================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左边AI -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,10" VerticalAlignment="Center">
                <Border Background="#4a6fa5" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                    <TextBlock Text="{Binding PlayerLeft.Name}" Foreground="White" FontSize="14"/>
                </Border>
                <Border Background="#27ae60" CornerRadius="12" Padding="12,6"
                        Visibility="{Binding PlayerLeft.IsCurrentTurn, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="思考中..." Foreground="White" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlayerLeft.IsThinking}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.3" Duration="0:0:0.5"
                                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <TextBlock Text="{Binding PlayerLeft.CardCount, StringFormat='剩余 {0} 张'}"
                           Foreground="#aaa" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding PlayerLeft.RoleDisplay}" Foreground="#FFD700"
                           FontSize="13" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 底牌区域 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Margin="0,2">
                <TextBlock Text="底牌:" Foreground="#aaa" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ItemsControl ItemsSource="{Binding LandlordCards}"
                              Visibility="{Binding LandlordCardsVisible, Converter={StaticResource BoolToVis}}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CardControl Width="42" Height="59" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="???" Foreground="#666" FontSize="12"
                           Visibility="{Binding LandlordCardsVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 右边AI -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="20,10" VerticalAlignment="Center">
                <TextBlock Text="{Binding PlayerRight.RoleDisplay}" Foreground="#FFD700"
                           FontSize="13" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding PlayerRight.CardCount, StringFormat='剩余 {0} 张'}"
                           Foreground="#aaa" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Border Background="#c0392b" CornerRadius="12" Padding="12,6"
                        Visibility="{Binding PlayerRight.IsCurrentTurn, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="思考中..." Foreground="White" FontSize="14"/>
                </Border>
                <Border Background="#4a6fa5" CornerRadius="12" Padding="12,6" Margin="10,0,0,0">
                    <TextBlock Text="{Binding PlayerRight.Name}" Foreground="White" FontSize="14"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ==================== 出牌展示 ==================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 洗牌动画覆盖层 -->
            <Canvas x:Name="ShuffleCanvas" Grid.ColumnSpan="3"
                    Visibility="Collapsed" IsHitTestVisible="False"
                    ClipToBounds="True">
                <Canvas.Background>
                    <SolidColorBrush Color="Black" Opacity="0.35"/>
                </Canvas.Background>
            </Canvas>

            <!-- 左边AI出牌 -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" MaxWidth="350">
                <TextBlock Text="{Binding PlayerLeft.LastAction}" Foreground="#FFD700"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                <ItemsControl ItemsSource="{Binding PlayerLeft.PlayedCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="-20,0,0,0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CardControl Width="56" Height="79"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- 中央区域 -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- 叫分提示 + 按钮 -->
                <StackPanel Visibility="{Binding IsBidPanelVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#aaa" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="1分" Command="{Binding Bid1Command}" Style="{StaticResource ActionButton}"
                                IsEnabled="{Binding CanBid1}"/>
                        <Button Content="2分" Command="{Binding Bid2Command}" Style="{StaticResource ActionButton}"
                                IsEnabled="{Binding CanBid2}"/>
                        <Button Content="3分" Command="{Binding Bid3Command}" Style="{StaticResource ActionButton}"
                                IsEnabled="{Binding CanBid3}"/>
                        <Button Content="不叫" Command="{Binding PassBidCommand}" Style="{StaticResource PassButton}"/>
                    </StackPanel>
                </StackPanel>

                <!-- 对局结果 + 确认按钮 -->
                <StackPanel Visibility="{Binding IsGameOver, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#FFD700" FontSize="22"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <Button Content="确认" Command="{Binding ConfirmGameOverCommand}"
                            Style="{StaticResource NewGameButton}"/>
                </StackPanel>

                <!-- 大厅：玩家列表 + 准备状态 -->
                <StackPanel Visibility="{Binding IsLobbyVisible, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Border Background="#16213e" CornerRadius="10" Padding="18,12"
                            BorderBrush="#333" BorderThickness="1" MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="房间玩家" Foreground="#aaa" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding LobbyPlayers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="14"
                                                   Margin="0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 新游戏 / 准备游戏 按钮 -->
                <Button Content="{Binding ReadyButtonText}" Command="{Binding ToggleReadyCommand}"
                        Style="{StaticResource NewGameButton}"
                        Visibility="{Binding IsNewGameVisible, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- 右边AI出牌 -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" MaxWidth="350">
                <TextBlock Text="{Binding PlayerRight.LastAction}" Foreground="#FFD700"
                           FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                <ItemsControl ItemsSource="{Binding PlayerRight.PlayedCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="-20,0,0,0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CardControl Width="56" Height="79"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- ==================== 玩家出牌 ==================== -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,3,0,0" MaxWidth="400">
            <TextBlock Text="{Binding PlayerBottom.LastAction}" Foreground="#FFD700"
                       FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,3"/>
            <ItemsControl ItemsSource="{Binding PlayerBottom.PlayedCards}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="-26,0,0,0"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:CardControl Width="61" Height="86"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- ==================== 操作按钮 + 手牌 ==================== -->
        <StackPanel Grid.Row="4" Margin="0,5,0,8" HorizontalAlignment="Center">
            <!-- 无牌可出提示 -->
            <TextBlock Text="{Binding HintNoPlayMessage}" Foreground="#FFD700" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,3"
                       Visibility="{Binding IsPlayPanelVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- 操作按钮行（角色标签 + 按钮 + 倒计时） -->
            <Grid Margin="20,0,0,2" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 玩家角色标签（垂直居中） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Border Background="#4a6fa5" CornerRadius="14" Padding="20,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding PlayerBottom.Name}" Foreground="White"
                                   FontSize="16" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#FFD700" CornerRadius="14" Padding="16,6">
                        <TextBlock Text="{Binding PlayerBottom.RoleDisplay}" Foreground="#333"
                                   FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <!-- 操作按钮（垂直居中） -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsPlayPanelVisible, Converter={StaticResource BoolToVis}}">
                    <Button Content="出牌" Command="{Binding PlayCardsCommand}" Style="{StaticResource ActionButton}"/>
                    <Button Content="不出" Command="{Binding PassPlayCommand}" Style="{StaticResource PassButton}"/>
                    <Button Content="提示" Command="{Binding HintCommand}" Style="{StaticResource HintButton}"/>
                    <!-- 出牌倒计时 -->
                    <Border Background="#333" CornerRadius="8" Padding="12,4" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsCountdownVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding TurnCountdownText}" Foreground="#FFD700"
                                   FontSize="18" FontWeight="Bold" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 手牌展示（顶部留选牌上移空间） -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          MaxHeight="180" HorizontalAlignment="Center" Margin="0,0,0,15">
                <ItemsControl x:Name="HandItemsControl" ItemsSource="{Binding PlayerBottom.Hand}"
                              Margin="45,25,10,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="-44.5,0,0,0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CardControl Width="89" Height="126"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- ==================== 断线投票面板（叠加层） ==================== -->
        <Border Background="#CC000000" Grid.RowSpan="5"
                Visibility="{Binding IsVoteVisible, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="380" Margin="20">
                <Border Background="#16213e" CornerRadius="12" Padding="28,24"
                        BorderBrush="#e74c3c" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="⚠️ 玩家断线" Foreground="#e74c3c" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding VoteMessage}" Foreground="#ddd" FontSize="15"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,0,0,20" TextAlignment="Center"/>

                        <!-- 投票按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Button Content="🛑 结束对局" Command="{Binding VoteEndCommand}"
                                    Background="#c0392b" Foreground="White" FontWeight="Bold"
                                    FontSize="14" Padding="20,8" Margin="0,0,10,0"
                                    BorderBrush="#922b21" BorderThickness="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#e74c3c"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="⏳ 等待重连" Command="{Binding VoteContinueCommand}"
                                    Background="#2980b9" Foreground="White" FontWeight="Bold"
                                    FontSize="14" Padding="20,8"
                                    BorderBrush="#1f618d" BorderThickness="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#3498db"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- 投票状态 -->
                        <TextBlock Text="{Binding VoteStatusMessage}" Foreground="#aaa" FontSize="13"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
