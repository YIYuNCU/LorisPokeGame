<UserControl x:Class="LolitaPoker.Core.Views.ModeSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ModeButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4a6fa5"/>
            <Setter Property="BorderBrush" Value="#2c3e50"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="24,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a8fc5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3a5f95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>    <!-- 菜单栏 -->
            <RowDefinition Height="*"/>     <!-- 内容 -->
        </Grid.RowDefinitions>

        <!-- ==================== 菜单栏 ==================== -->
        <Border Grid.Row="0" Background="#111" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：标题 -->
                <TextBlock Grid.Column="0" Text="萝莉丝扑克" Foreground="#FFD700"
                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- ==================== 内容区 ==================== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="480" Margin="40,20">

                <!-- 大标题 -->
                <TextBlock Text="萝莉丝扑克" FontSize="40" FontWeight="Bold"
                           Foreground="#FFD700" HorizontalAlignment="Center"/>
                <TextBlock Text="斗 地 主" FontSize="22"
                           Foreground="#aaa" HorizontalAlignment="Center" Margin="0,2,0,30"/>

                <!-- ======== 模式1：人机对战 ======== -->
                <Border Background="#16213e" CornerRadius="12" Padding="22,16" Margin="0,0,0,14"
                        BorderBrush="#4a6fa5" BorderThickness="1.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎮" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="人机模式" FontSize="20" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="与电脑 AI 对战，随时随地畅玩" Foreground="#888"
                                       FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="开 始"
                                Command="{Binding StartAIGameCommand}"
                                Style="{StaticResource ModeButton}" Background="#27ae60"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ======== 模式2：VPet 联机 ======== -->
                <Border Background="#16213e" CornerRadius="12" Padding="22,16" Margin="0,0,0,14"
                        BorderBrush="#e67e22" BorderThickness="1.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐾" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="VPet 联机" FontSize="20" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="通过 VPet 访客表与好友联机对战" Foreground="#888"
                                       FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="使用说明"
                                Command="{Binding OpenVPetLanInfoCommand}"
                                Style="{StaticResource ModeButton}" Background="#e67e22"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ======== 模式3：服务器模式 ======== -->
                <Border Background="#16213e" CornerRadius="12" Padding="22,16" Margin="0,0,0,14"
                        BorderBrush="#9b59b6" BorderThickness="1.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="服务器模式" FontSize="20" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="连接远程服务器，与全球玩家对战" Foreground="#888"
                                       FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="配 置"
                                Command="{Binding OpenServerSettingsCommand}"
                                Style="{StaticResource ModeButton}" Background="#9b59b6"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
